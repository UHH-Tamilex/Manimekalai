      <titleStmt>
            <title xml:lang="ta"><term xml:lang="en">Canto 7:</term> tuyil eḻuppiya kātai</title> 
            <title type="sub">The Canto in which [Maṇimēkalā Teyvam] wakes [Cutamati] from Sleep (126 lines)</title>
      </titleStmt>
      <publicationStmt><p/></publicationStmt>
      <sourceDesc>
        <msDesc xml:lang="en">
          <msIdentifier>
          </msIdentifier>
           <msContents>
            <summary>
              <p>7.1-14 (14 lines) <term xml:lang="ta">Maṇimēkalā Teyvam</term> goes to <term xml:lang="ta">Utayakumāraṉ</term>, who was passing a sleepless night of
                love-sickness after seeing <term xml:lang="ta">Maṇimēkalai</term> in the grove
                (Canto 5) and urges him to give up his love, for the sake of good kingship.</p>
            </summary>
          </msContents>    
        </msDesc>
      </sourceDesc>
    </fileDesc>
